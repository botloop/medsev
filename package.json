{
  "name": "pcg-personnel-system",
  "version": "1.0.0",
  "description": "Philippine Coast Guard Personnel Management System - React + Node.js with Firestore",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "client": "npm run dev --workspace=client",
    "server": "npm run dev --workspace=server",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --workspaces",
    "install:all": "npm install && npm install --workspaces"
  },
  "keywords": [
    "philippine-coast-guard",
    "personnel-management",
    "react",
    "nodejs",
    "typescript",
    "firestore"
  ],
  "author": "SN2 Acosta PCG",
  "license": "UNLICENSED",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
