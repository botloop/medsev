rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isValidPDF() {
      return request.resource.contentType == 'application/pdf';
    }

    function isValidMedicalFile() {
      return isValidImage() || isValidPDF();
    }

    function isUnder5MB() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // Profile photos
    match /personnel-photos/{personnelId}/{fileName} {
      // All authenticated users can read
      allow read: if isAuthenticated();

      // Only authenticated users can upload images under 5MB
      allow write: if isAuthenticated()
                   && isValidImage()
                   && isUnder5MB();

      // Only authenticated users can delete
      allow delete: if isAuthenticated();
    }

    // Medical results
    match /medical-results/{personnelId}/step{stepNumber}/{fileName} {
      // All authenticated users can read
      allow read: if isAuthenticated();

      // Only authenticated users can upload valid medical files under 5MB
      allow write: if isAuthenticated()
                   && isValidMedicalFile()
                   && isUnder5MB();

      // Only authenticated users can delete
      allow delete: if isAuthenticated();
    }

    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
